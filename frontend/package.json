{
  "name": "turk-food",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://Abror-maker.github.io/turk-food",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "cross-env VITE_BASE_PATH=/turk-food/ VITE_STATIC_DATA=true vite build",
    "deploy": "npm run build:pages && node scripts/copy-404.js && gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:pages": "cross-env VITE_BASE_PATH=/turk-food/ vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
